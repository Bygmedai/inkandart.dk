---
layout: layouts/base.njk
pagination:
  data: siteLocales
  size: 1
  alias: lang
siteLocales: [da, en]
permalink: "{% if lang == 'en' %}/en/walk-in/{% else %}/walk-in/{% endif %}"
eleventyComputed:
  title: "{% if lang == 'en' %}Walk-in Tattoo Copenhagen · Ink & Art{% else %}Walk-in tatovering København · Ink & Art{% endif %}"
  description: "{% if lang == 'en' %}Walk-in tattoo and piercing at Larsbjørnsstræde 13, Copenhagen. No booking needed — just drop by or WhatsApp us. From DKK 800.{% else %}Walk-in tatovering og piercing på Larsbjørnsstræde 13, København. Ingen booking nødvendig — drop forbi eller skriv på WhatsApp. Fra 800 kr.{% endif %}"
---
<section class="walk-in hero hero--walkin">
  <video class="hero__video" autoplay muted loop playsinline preload="metadata" poster="/_assets/img/walkin-poster.jpg" aria-hidden="true">
    <source src="/_assets/video/walkin.mp4" type="video/mp4">
  </video>
  <h1 class="hero__wordmark">
    <span class="hero__wordmark-line">{{ "walkIn.youAreHere" | t(lang) | upper }}</span>
    <span class="hero__wordmark-cph">{{ "walkIn.comeInside" | t(lang) | upper }}<span class="dot">.</span></span>
  </h1>

  <div class="walk-in__stamps" aria-hidden="true">
    <div class="stamp stamp--red walk-in__stamp-status" data-status-stamp>
      {{ "walkIn.fallback" | t(lang) }}
    </div>
    <div class="stamp stamp--ink walk-in__stamp-price">
      {{ "walkIn.priceStamp" | t(lang) }}
    </div>
  </div>

  <div class="about-card">
    <div class="about-card__file">{{ "walkIn.fileLabel" | t(lang) }}</div>
    <p class="about-card__text">{{ "walkIn.blurb" | t(lang) }}</p>
    <div class="about-card__cta">
      <a href="https://wa.me/{{ site.whatsapp | replace('+', '') | replace(' ', '') }}"
         class="btn btn--primary"
         target="_blank" rel="noopener noreferrer">
        WHATSAPP ↗
      </a>
      <a href="tel:{{ site.phoneIntl }}" class="btn btn--ghost">{{ "cta.callShop" | t(lang) }}&nbsp;{{ site.phone | replace(" ", "&nbsp;") | safe }}</a>
    </div>
    <p class="about-card__live" data-status-text aria-live="polite">
      {{ "walkIn.fallback" | t(lang) }}
    </p>
  </div>

  {%- include "partials/lang-toggle.njk" -%}
</section>

<section class="wi-offer" aria-labelledby="wi-offer-h">
  <div class="wi-offer__inner">
    <p class="wi-offer__file">{% if lang == 'en' %}Walk-in offer{% else %}Walk-in tilbud{% endif %}</p>
    <h2 id="wi-offer-h" class="wi-offer__title">2 {% if lang == 'en' %}small tattoos{% else %}små tattoos{% endif %} — 900,-</h2>
    <p class="wi-offer__sub">{% if lang == 'en' %}Two small tattoos, walk-in — no booking. Drop by Larsbjørnsstræde 13; pay online or in the studio.{% else %}To små tatoveringer, walk-in — ingen booking. Kom forbi Larsbjørnsstræde 13; betal online eller i studiet.{% endif %}</p>
    <a class="btn btn--primary" href="{{ site.shopUrl }}/shop">{% if lang == 'en' %}See it in the shop{% else %}Se tilbuddet i shoppen{% endif %} <span aria-hidden="true">→</span></a>
  </div>
</section>

{#- Spejlet fra appens Studio-tab (flette-plan app→site): ydelser + priser +
    prebook-CTA, så siden dækker BÅDE walk-in og booking — appens mønster. -#}
<section class="flash wi-studio" aria-labelledby="wi-services-h">
  <div class="aftercare__section" style="margin-top:0;border-top:none;padding-top:10px">
    <p class="flash__file">{{ "studio.servicesLabel" | t(lang) }}</p>
    <h2 id="wi-services-h" class="flash__prices-title">{{ "studio.servicesTitle" | t(lang) }}</h2>
    <ol class="aftercare__steps">
      {%- for y in i18n.studio.services %}
      <li class="aftercare__step">
        <span class="aftercare__step-num">{% if loop.index < 10 %}0{% endif %}{{ loop.index }}</span>
        <div>
          <h3 class="aftercare__step-title">{{ y.k[lang] }}</h3>
          <p class="aftercare__step-body">{{ y.v[lang] }}</p>
        </div>
      </li>
      {%- endfor %}
    </ol>
  </div>

  <div class="flash__prices">
    <p class="flash__file">{{ "studio.pricesLabel" | t(lang) }}</p>
    <h2 class="flash__prices-title">{{ "studio.pricesTitle" | t(lang) }}</h2>
    <dl class="flash__price-list">
      {%- for p in i18n.studio.prices %}
      <div class="flash__price-row">
        <dt class="flash__price-label">{{ p.k[lang] }}</dt>
        <dd class="flash__price-note">{{ p.v[lang] }}</dd>
      </div>
      {%- endfor %}
    </dl>
    <p class="flash__prices-footnote">{{ "studio.pricesNote" | t(lang) }}</p>
  </div>

  <div class="aftercare__reassure">
    <p class="flash__file">{{ "studio.bookLabel" | t(lang) }}</p>
    <h2 class="flash__prices-title" style="font-size:clamp(20px,2.6vw,28px)">{{ "studio.bookTitle" | t(lang) }}</h2>
    <p class="aftercare__reassure-body">{{ "studio.bookBody" | t(lang) }}</p>
    <div class="about-card__cta">
      <a class="btn btn--primary" href="{{ site.bookingUrl }}" target="_blank" rel="noopener noreferrer">{{ "studio.bookCta" | t(lang) }} ↗</a>
      <a class="btn btn--outline" href="{% if lang == 'en' %}/en/find-your-tattoo/{% else %}/find-din-tatovering/{% endif %}">{{ "studio.wizardCta" | t(lang) }} →</a>
      <a class="btn btn--ghost" href="{% if lang == 'en' %}/en/aftercare/{% else %}/aftercare/{% endif %}">{{ "studio.aftercareCta" | t(lang) }} →</a>
    </div>
    <p class="flash__prices-footnote" style="margin-bottom:0">{{ "studio.bookHint" | t(lang) }}</p>
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "{% if lang == 'en' %}Home{% else %}Forside{% endif %}", "item": "{{ site.url }}{% if lang == 'en' %}/en/{% else %}/{% endif %}" },
    { "@type": "ListItem", "position": 2, "name": "{{ 'nav.walkIn' | t(lang) }}", "item": "{{ site.url }}{{ page.url }}" }
  ]
}
</script>

<script src="/_assets/js/walk-in.js" defer></script>
