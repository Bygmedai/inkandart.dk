<!DOCTYPE html>
<html lang="{{ lang or 'en' }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#0c0b0a">
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">
  {#- Bevidst noindex indtil launch (adult, ikke annonceret). Sæt `published: true` i front matter for at indeksere. -#}
  {% if not published %}<meta name="robots" content="noindex, nofollow">{% endif %}
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <link rel="icon" href="/_assets/img/favicon-32.png" type="image/png" sizes="32x32">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">

  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:image" content="{{ site.url }}{{ ogImage or '/_assets/img/og-image.jpg' }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:locale" content="{{ 'da_DK' if lang == 'da' else 'en_DK' }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }}">
  <meta name="twitter:description" content="{{ description }}">
  <meta name="twitter:image" content="{{ site.url }}{{ ogImage or '/_assets/img/og-image.jpg' }}">

  <link rel="stylesheet" href="/_assets/css/kinky-sundae.css">
</head>
<body>
  <a href="#main" class="skip-link">{% if lang == 'da' %}Gå til indhold{% else %}Skip to content{% endif %}</a>
  <div class="grain" aria-hidden="true"></div>
  <main id="main" tabindex="-1">
    {{- content | safe -}}
  </main>
  <script src="/_assets/js/subscribe.js" defer></script>
</body>
</html>
