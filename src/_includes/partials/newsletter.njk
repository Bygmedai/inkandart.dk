{% set lang = lang or (page.url | pageLang) %}
<section class="newsletter" aria-labelledby="nl-title">
  <div class="newsletter__inner">
    <p class="newsletter__file">{{ "newsletter.file" | t(lang) }}</p>
    <h2 class="newsletter__title" id="nl-title">{{ "newsletter.title" | t(lang) }}</h2>
    <p class="newsletter__lead">{{ "newsletter.lead" | t(lang) }}</p>
    <form id="newsletter-form" class="newsletter__form" data-subscribe data-source="footer" data-lang="{{ lang }}" novalidate>
      <label class="newsletter__field">
        <span class="visually-hidden">{{ "newsletter.emailLabel" | t(lang) }}</span>
        <input type="email" name="email" inputmode="email" autocomplete="email"
               placeholder="{{ 'newsletter.placeholder' | t(lang) }}" required aria-required="true" />
      </label>
      {# honeypot: hidden from humans, tempting to bots #}
      <div class="newsletter__hp" aria-hidden="true">
        <label>Company<input type="text" name="company" tabindex="-1" autocomplete="off" /></label>
      </div>
      <button type="submit" class="btn btn--primary">{{ "newsletter.button" | t(lang) }}</button>
      <p class="newsletter__status" data-nl-status role="status" aria-live="polite"></p>
      <p class="newsletter__consent">
        {{ "newsletter.consent" | t(lang) }}
        <a href="{% if lang == 'en' %}/en/privacy/{% else %}/privatlivspolitik/{% endif %}">{{ "nav.privacy" | t(lang) }}</a>.
      </p>
      <noscript>
        <p class="newsletter__consent">
          {{ "newsletter.nojs" | t(lang) }}
          <a href="{{ site.instagram }}" target="_blank" rel="noopener noreferrer">Instagram</a>.
        </p>
      </noscript>
    </form>
  </div>
</section>
