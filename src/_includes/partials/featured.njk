{% set lang = lang or (page.url | pageLang) %}
<section class="featured" aria-labelledby="featured-heading">
  <p class="featured__file">{% if lang == 'en' %}In the house{% else %}I huset{% endif %}</p>
  <h2 id="featured-heading" class="visually-hidden">{% if lang == 'en' %}In the house — the people behind the needle{% else %}I huset — menneskene bag nålen{% endif %}</h2>

  <div class="featured__grid">
    {#- Residency lead — data-driven fra _data/residency.json (gated på active) -#}
    {%- if residency.active %}
    <article class="featured__card featured__card--lead">
      <a class="featured__media" href="{% if lang == 'en' %}/en/artists/{{ residency.artistSlug }}/{% else %}/artister/{{ residency.artistSlug }}/{% endif %}">
        <img src="/_assets/img/artists/{{ residency.artistSlug }}/portrait.jpg" alt="{% if lang == 'en' %}{{ residency.name }}, guest artist in residence at Ink &amp; Art{% else %}{{ residency.name }}, gæsteartist in residence hos Ink &amp; Art{% endif %}" loading="eager" decoding="async" width="600" height="800">
        <span class="featured__flag js-residency">{% if lang == 'en' %}In the house now{% else %}I huset nu{% endif %}</span>
      </a>
      <div class="featured__body">
        <p class="featured__kicker">{% if lang == 'en' %}Guest artist · in residence · just flew in from {{ residency.fromEn }}{% else %}Gæsteartist · in residence · lige landet fra {{ residency.fromDa }}{% endif %}</p>
        <h3 class="featured__title">{% if lang == 'en' %}Welcome, {{ residency.firstName }}.{% else %}Velkommen, {{ residency.firstName }}.{% endif %}</h3>
        <p class="featured__lede">{% if lang == 'en' %}{{ residency.name }} has flown in from {{ residency.fromEn }} and is with us — {{ residency.rangeEn }}. {{ residency.disciplinesEn }}. Come by and give {{ residency.firstName }} a proper Copenhagen welcome: {{ residency.hoursEn }}.{% else %}{{ residency.name }} er landet fra {{ residency.fromDa }} og er hos os — {{ residency.rangeDa }}. {{ residency.disciplinesDa }}. Kom forbi og byd {{ residency.firstName }} ordentligt velkommen: {{ residency.hoursDa }}.{% endif %}</p>
        <p class="featured__meta"><a href="https://www.instagram.com/{{ residency.instagram }}/" target="_blank" rel="noopener noreferrer">@{{ residency.instagram }} ↗</a></p>
        <div class="featured__cta">
          <a class="btn btn--primary" href="{% if lang == 'en' %}/en/artists/{{ residency.artistSlug }}/{% else %}/artister/{{ residency.artistSlug }}/{% endif %}">{% if lang == 'en' %}Meet {{ residency.firstName }}{% else %}Mød {{ residency.firstName }}{% endif %} →</a>
          <a class="btn btn--outline" href="{% if lang == 'en' %}/en/walk-in/{% else %}/walk-in/{% endif %}">Walk-in ↗</a>
        </div>
      </div>
    </article>
    {%- endif %}

    {#- NIZAR — founder (prominence) -#}
    <article class="featured__card">
      <a class="featured__media" href="{% if lang == 'en' %}/en/artists/nizar/{% else %}/artister/nizar/{% endif %}">
        <img src="/_assets/img/artists/nizar/portrait.jpg" alt="{% if lang == 'en' %}Nizar, founder &amp; artist at Ink &amp; Art{% else %}Nizar, founder &amp; artist hos Ink &amp; Art{% endif %}" loading="lazy" decoding="async" width="600" height="800">
      </a>
      <div class="featured__body">
        <p class="featured__kicker">Founder &amp; Artist</p>
        <h3 class="featured__title">{% if lang == 'en' %}The soul of the place.{% else %}Stedets ånd.{% endif %}</h3>
        <p class="featured__lede">{% if lang == 'en' %}The man behind Ink &amp; Art. Custom &amp; freehand — your tattoo is shaped by the person in front of him. A chapter, not just a motif.{% else %}Manden bag Ink &amp; Art. Custom &amp; freehånd — din tatovering formes af mennesket foran ham. Et kapitel, ikke bare et motiv.{% endif %}</p>
        <div class="featured__cta">
          <a class="btn btn--primary" href="{% if lang == 'en' %}/en/artists/nizar/{% else %}/artister/nizar/{% endif %}">{% if lang == 'en' %}Meet Nizar{% else %}Mød Nizar{% endif %} →</a>
        </div>
      </div>
    </article>

    {#- ISAC — fast artist (spejlet fra appens § Menneskene) -#}
    <article class="featured__card">
      <a class="featured__media" href="{% if lang == 'en' %}/en/artists/isac/{% else %}/artister/isac/{% endif %}">
        <img src="/_assets/img/artists/isac/portrait.jpg" alt="{% if lang == 'en' %}Isac, resident artist at Ink &amp; Art{% else %}Isac, fast artist hos Ink &amp; Art{% endif %}" loading="lazy" decoding="async" width="600" height="800">
      </a>
      <div class="featured__body">
        <p class="featured__kicker">{% if lang == 'en' %}Resident artist · blackwork &amp; fineline{% else %}Fast artist · blackwork &amp; fineline{% endif %}</p>
        <h3 class="featured__title">{% if lang == 'en' %}He meets you before the needle does.{% else %}Han møder dig før nålen gør.{% endif %}</h3>
        <p class="featured__lede">{% if lang == 'en' %}Isac loves human contact and presence. Illustrative blackwork, fineline and dotwork — and 100% of himself in every tattoo.{% else %}Isac elsker menneskekontakt og nærvær. Illustrativ blackwork, fineline og dotwork — og 100% af sig selv i hver tatovering.{% endif %}</p>
        <div class="featured__cta">
          <a class="btn btn--primary" href="{% if lang == 'en' %}/en/artists/isac/{% else %}/artister/isac/{% endif %}">{% if lang == 'en' %}Meet Isac{% else %}Mød Isac{% endif %} →</a>
        </div>
      </div>
    </article>

    {#- MARIA — piercer (spejlet fra appens Maria-fokus) -#}
    <article class="featured__card">
      <a class="featured__media" href="{% if lang == 'en' %}/en/artists/maria/{% else %}/artister/maria/{% endif %}">
        <img src="/_assets/img/artists/maria/portrait.jpg" alt="{% if lang == 'en' %}Maria, piercer at Ink &amp; Art{% else %}Maria, piercer hos Ink &amp; Art{% endif %}" loading="lazy" decoding="async" width="600" height="800">
      </a>
      <div class="featured__body">
        <p class="featured__kicker">{% if lang == 'en' %}Piercer · jewellery{% else %}Piercer · smykker{% endif %}</p>
        <h3 class="featured__title">{% if lang == 'en' %}Piercing as craft.{% else %}Piercing som håndværk.{% endif %}</h3>
        <p class="featured__lede">{% if lang == 'en' %}With Maria you don't just buy a piercing — it's set properly, calmly and with care. One small detail. The rest is you.{% else %}Hos Maria køber du ikke bare en piercing — den bliver sat ordentligt, roligt og med omtanke. Én lille detalje. Resten er dig.{% endif %}</p>
        <div class="featured__cta">
          <a class="btn btn--primary" href="{% if lang == 'en' %}/en/artists/maria/{% else %}/artister/maria/{% endif %}">{% if lang == 'en' %}Meet Maria{% else %}Mød Maria{% endif %} →</a>
        </div>
      </div>
    </article>
  </div>
</section>
