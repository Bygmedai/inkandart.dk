{% set lang = page.url | pageLang %}
{% set privacyUrl %}{% if lang == "en" %}/en/privacy/{% else %}/privatlivspolitik/{% endif %}{% endset %}
<aside id="cookie-banner" class="cookie-banner" role="dialog" aria-labelledby="cookie-banner-title" hidden>
  <div class="cookie-banner__inner">
    <h2 id="cookie-banner-title" class="cookie-banner__title">{{ "cookie.title" | t(lang) }}</h2>
    <p class="cookie-banner__body">
      {{ "cookie.body" | t(lang) }} <a href="{{ privacyUrl }}">{{ "cookie.privacyLink" | t(lang) }}</a>.
    </p>
    <div class="cookie-banner__buttons">
      <button type="button" class="btn btn--outline" data-consent="reject">{{ "cookie.reject" | t(lang) }}</button>
      <button type="button" class="btn btn--outline" data-consent="accept">{{ "cookie.accept" | t(lang) }}</button>
    </div>
  </div>
</aside>
