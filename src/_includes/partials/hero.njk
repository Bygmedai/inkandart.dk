{% set lang = lang or (page.url | pageLang) %}
<section class="hero">
  <video class="hero__video" autoplay muted loop playsinline preload="metadata" poster="/_assets/img/hero-poster.jpg" aria-hidden="true">
    <source src="/_assets/video/hero.mp4" type="video/mp4">
  </video>
  <h1 class="hero__wordmark">
    <span class="hero__wordmark-line">INK <span class="amp">&amp;</span> ART</span>
    <span class="hero__wordmark-cph">COPENHAGEN<span class="dot">.</span></span>
  </h1>

  {#- Stempler — to af tre er funktionelle entry-points til sub-sider. -#}
  <a href="{% if lang == 'en' %}/en/walk-in/{% else %}/walk-in/{% endif %}" class="stamp stamp--red hero__stamp-1 hero__stamp--link">{{ "hero.stamps.walkInsOk" | t(lang) }} ↗</a>
  <a href="{% if lang == 'en' %}/en/artists/{% else %}/artister/{% endif %}" class="stamp stamp--ink hero__stamp-2 hero__stamp--link">{{ "hero.stamps.ourArtists" | t(lang) }} ↗</a>
  <a href="{{ site.shopUrl }}" class="stamp stamp--ink hero__stamp-3 hero__stamp--link" target="_blank" rel="noopener noreferrer">{{ "hero.stamps.shop" | t(lang) }} ↗</a>

  <div class="about-card">
    <p class="about-card__text">{%- if lang == "en" -%}
      Tattoo and piercing studio at <strong>{{ site.address.street }}</strong> — heart of Copenhagen. Classic craft, sharp attitude, open late.
      {%- else -%}
      Tatovør- og piercingstudio på <strong>{{ site.address.street }}</strong> — hjertet af København. Klassisk håndværk, fed attitude, sent åbent.
      {%- endif -%}</p>
    <div class="about-card__cta">
      <a href="{{ site.bookingUrl }}" class="btn btn--primary" target="_blank" rel="noopener noreferrer">{{ "cta.bookNow" | t(lang) }} <span aria-hidden="true">→</span></a>
      <a href="tel:{{ site.phoneIntl }}" class="btn btn--ghost">{{ "cta.callShop" | t(lang) }}&nbsp;{{ site.phone | replace(" ", "&nbsp;") | safe }}</a>
    </div>
  </div>

  {%- include "partials/lang-toggle.njk" -%}
</section>
