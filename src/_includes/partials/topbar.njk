{% set lang = page.url | pageLang %}
<header class="topbar" aria-label="{{ 'common.siteStatus' | t(lang) }}">
{%- set isHome = page.url == "/" or page.url == "/en/" -%}
{%- set isWalkIn = page.url == "/walk-in/" or page.url == "/en/walk-in/" -%}
{%- set isArtistsIndex = page.url == "/artister/" or page.url == "/en/artists/" -%}
{%- set isArtistDeep = page.url.match("^/artister/[^/]+/$") or page.url.match("^/en/artists/[^/]+/$") -%}
{%- set isFind    = page.url == "/find-din-tatovering/" or page.url == "/en/find-your-tattoo/" -%}
{%- set isFlash   = page.url == "/flash/" or page.url == "/en/flash/" -%}
{%- set isPrivacy = page.url == "/privatlivspolitik/" or page.url == "/en/privacy/" -%}
{%- set isLead = page.url == "/del-din-ide/" or page.url == "/en/share-your-idea/" -%}
{%- set is404 = page.url == "/404.html" or page.url == "/en/404.html" -%}

{%- if isHome %}
  <span>★ ESTD · KBH ★</span>
  <span class="topbar__issue js-residency"><a href="{% if lang == 'en' %}/en/artists/koko/{% else %}/artister/koko/{% endif %}" class="topbar__back">★ {% if lang == 'en' %}WELCOME KOKO · IN RESIDENCE 7–21 JUL{% else %}VELKOMMEN KOKO · IN RESIDENCE 7.–21. JULI{% endif %} ↗</a></span>
  <span class="topbar__live" data-status-live>● {{ "common.openSince" | t(lang) }}</span>

{%- elif isWalkIn %}
  <span><a href="{% if lang == 'en' %}/en/{% else %}/{% endif %}" class="topbar__back">← {{ site.shortName | upper }}</a></span>
  <span class="topbar__issue">{{ "nav.walkIn" | t(lang) | upper }}</span>
  <span class="topbar__live" data-status-live aria-live="polite">● {{ "common.live" | t(lang) }}</span>

{%- elif isArtistsIndex %}
  <span><a href="{% if lang == 'en' %}/en/{% else %}/{% endif %}" class="topbar__back">← {{ site.shortName | upper }}</a></span>
  <span class="topbar__issue">{{ "nav.artists" | t(lang) | upper }}</span>
  <span class="topbar__live">★ {% if lang == 'en' %}RESIDENTS + GUESTS{% else %}FASTE + GÆSTER{% endif %}</span>

{%- elif isArtistDeep %}
  <span><a href="{% if lang == 'en' %}/en/artists/{% else %}/artister/{% endif %}" class="topbar__back">← {{ "nav.artists" | t(lang) | upper }}</a></span>
  <span class="topbar__issue">{{ artistName | upper if artistName else (page.fileSlug | upper) }}</span>
  <span class="topbar__live">{% if artistStyles %}★ {{ artistStyles | upper }}{% endif %}</span>

{%- elif isFlash %}
  <span><a href="{% if lang == 'en' %}/en/{% else %}/{% endif %}" class="topbar__back">← {{ site.shortName | upper }}</a></span>
  <span class="topbar__issue">{{ "nav.flash" | t(lang) | upper }}</span>
  <span class="topbar__live">★ {% if lang == 'en' %}WALK-IN READY{% else %}KLAR TIL WALK-IN{% endif %}</span>

{%- elif isFind %}
  <span><a href="{% if lang == 'en' %}/en/{% else %}/{% endif %}" class="topbar__back">← {{ site.shortName | upper }}</a></span>
  <span class="topbar__issue">MATCH.TXT</span>
  <span class="topbar__live">★ {% if lang == 'en' %}3 QUESTIONS{% else %}3 SPØRGSMÅL{% endif %}</span>

{%- elif isLead %}
  <span><a href="{% if lang == 'en' %}/en/{% else %}/{% endif %}" class="topbar__back">← {{ site.shortName | upper }}</a></span>
  <span class="topbar__issue">{{ "nav.lead" | t(lang) | upper }}</span>
  <span class="topbar__live">★ {% if lang == 'en' %}48H REPLY{% else %}SVAR INDEN 48T{% endif %}</span>

{%- elif isPrivacy %}
  <span><a href="{% if lang == 'en' %}/en/{% else %}/{% endif %}" class="topbar__back">← {{ site.shortName | upper }}</a></span>
  <span class="topbar__issue">{{ "nav.privacy" | t(lang) | upper }}</span>
  <span class="topbar__live">● {% if lang == 'en' %}LAST UPDATED{% else %}SENEST OPDATERET{% endif %} 2026-05-02</span>

{%- elif is404 %}
  <span><a href="{% if lang == 'en' %}/en/{% else %}/{% endif %}" class="topbar__back">← {{ site.shortName | upper }}</a></span>
  <span class="topbar__issue">404 NOT FOUND</span>
  <span class="topbar__live">● BAD URL</span>

{%- else %}
  <span>★ ESTD · KBH ★</span>
{%- endif %}
</header>
