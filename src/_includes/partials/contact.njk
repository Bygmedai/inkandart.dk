{% set lang = lang or (page.url | pageLang) %}
<article class="card card--paper" aria-labelledby="contact-heading">
  <h2 id="contact-heading" class="visually-hidden">{% if lang == "en" %}Contact{% else %}Kontakt{% endif %}</h2>

  <ul class="contact__list">
    <li>
      <span aria-hidden="true">📞</span>
      <a href="tel:{{ site.phoneIntl }}">{{ site.phone | replace(" ", "&nbsp;") | safe }}</a>
    </li>
    <li>
      <span aria-hidden="true">💬</span>
      <a href="https://wa.me/{{ site.whatsapp | replace('+', '') | replace(' ', '') }}" target="_blank" rel="noopener noreferrer">WHATSAPP</a>
    </li>
    <li>
      <span aria-hidden="true">◎</span>
      <a href="{{ site.instagram }}" target="_blank" rel="noopener noreferrer">INSTAGRAM</a>
    </li>
  </ul>

  <a href="{{ site.bookingUrl }}" class="btn btn--primary" target="_blank" rel="noopener noreferrer" data-ga-event="book" data-ga-label="contact">{{ "cta.bookNow" | t(lang) }} <span aria-hidden="true">→</span></a>
</article>
